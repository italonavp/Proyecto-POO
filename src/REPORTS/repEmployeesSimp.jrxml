	<queryString language="SQL">
		<![CDATA[SELECT
     E."EmployeeID" AS Employees_EmployeeID,
     E."LastName" AS Employees_LastName,
     E."FirstName" AS Employees_FirstName,
     E."Title" AS Employees_Title,
     E."City" AS Employees_City,
     E."HomePhone" AS Employees_HomePhone,
     ISNULL(J."FirstName" + ' ' + J."LastName", 'None') AS Jefe_Nombre
FROM
     "dbo"."Employees" E
LEFT JOIN 
     "dbo"."Employees" J ON E."ReportsTo" = J."EmployeeID"]]>
	</queryString>
	<field name="Employees_EmployeeID" class="java.lang.Integer"/>
	<field name="Employees_LastName" class="java.lang.String"/>
	<field name="Employees_FirstName" class="java.lang.String"/>
