<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="FichaEmpleado" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="512f92de-8bea-4fc5-85c7-212274466d0e">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="32"/>
	<parameter name="param_id_empleado" class="java.lang.Integer"/>
	<parameter name="IMAGEN" class="java.io.InputStream"/>
	<queryString>
		<![CDATA[SELECT
     E."EmployeeID" AS Employees_EmployeeID,
     E."LastName" AS Employees_LastName,
     E."FirstName" AS Employees_FirstName,
     E."Title" AS Employees_Title,
     E."TitleOfCourtesy" AS Employees_TitleOfCourtesy,
     E."BirthDate" AS Employees_BirthDate,
     E."HireDate" AS Employees_HireDate,
     E."Address" AS Employees_Address,
     E."City" AS Employees_City,
     E."Country" AS Employees_Country,
     E."HomePhone" AS Employees_HomePhone,
     E."Notes" AS Employees_Notes,
     ISNULL(J."FirstName" + ' ' + J."LastName", 'None') AS Jefe_Nombre
FROM
     "dbo"."Employees" E
LEFT JOIN 
     "dbo"."Employees" J ON E."ReportsTo" = J."EmployeeID"
WHERE 
     E."EmployeeID" = $P{param_id_empleado}]]>
	</queryString>
	<field name="Employees_EmployeeID" class="java.lang.Integer"/>
