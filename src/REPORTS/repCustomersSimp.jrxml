	<subDataset name="New Dataset 1" uuid="01ec0693-c62b-4b97-bc32-b63e905c7818">
		<queryString language="SQL">
			SELECT
     CustomerCustomerDemo."CustomerID" AS CustomerCustomerDemo_CustomerID,
     CustomerCustomerDemo."CustomerTypeID" AS CustomerCustomerDemo_CustomerTypeID,
     Categories."CategoryID" AS Categories_CategoryID,
     Categories."CategoryName" AS Categories_CategoryName,
     Categories."Description" AS Categories_Description,
     Categories."Picture" AS Categories_Picture,
     CustomerDemographics."CustomerTypeID" AS CustomerDemographics_CustomerTypeID,
     CustomerDemographics."CustomerDesc" AS CustomerDemographics_CustomerDesc,
     Customers."CustomerID" AS Customers_CustomerID,
     Customers."CompanyName" AS Customers_CompanyName,
     Customers."ContactName" AS Customers_ContactName,
     Customers."ContactTitle" AS Customers_ContactTitle,
     Customers."Address" AS Customers_Address,
     Customers."City" AS Customers_City,
     Customers."Region" AS Customers_Region,
     Customers."PostalCode" AS Customers_PostalCode,
     Customers."Country" AS Customers_Country,
     Customers."Phone" AS Customers_Phone,
     Customers."Fax" AS Customers_Fax,
     Employees."EmployeeID" AS Employees_EmployeeID,
     Employees."LastName" AS Employees_LastName,
     Employees."FirstName" AS Employees_FirstName,
     Employees."Title" AS Employees_Title,
     Employees."TitleOfCourtesy" AS Employees_TitleOfCourtesy,
     Employees."BirthDate" AS Employees_BirthDate,
     Employees."HireDate" AS Employees_HireDate,
     Employees."Address" AS Employees_Address,
     Employees."City" AS Employees_City,
     Employees."Region" AS Employees_Region,
     Employees."PostalCode" AS Employees_PostalCode,
     Employees."Country" AS Employees_Country,
     Employees."HomePhone" AS Employees_HomePhone,
     Employees."Extension" AS Employees_Extension,
     Employees."Photo" AS Employees_Photo,
     Employees."Notes" AS Employees_Notes,
     Employees."ReportsTo" AS Employees_ReportsTo,
     Employees."PhotoPath" AS Employees_PhotoPath,
     EmployeeTerritories."EmployeeID" AS EmployeeTerritories_EmployeeID,
     EmployeeTerritories."TerritoryID" AS EmployeeTerritories_TerritoryID,
     Order_Details."OrderID" AS Order_Details_OrderID,
     Order_Details."ProductID" AS Order_Details_ProductID,
     Order_Details."UnitPrice" AS Order_Details_UnitPrice,
     Order_Details."Quantity" AS Order_Details_Quantity,
     Order_Details."Discount" AS Order_Details_Discount,
     Orders."OrderID" AS Orders_OrderID,
     Orders."CustomerID" AS Orders_CustomerID,
     Orders."EmployeeID" AS Orders_EmployeeID,
     Orders."OrderDate" AS Orders_OrderDate,
     Orders."RequiredDate" AS Orders_RequiredDate,
     Orders."ShippedDate" AS Orders_ShippedDate,
     Orders."ShipVia" AS Orders_ShipVia,
     Orders."Freight" AS Orders_Freight,
     Orders."ShipName" AS Orders_ShipName,
     Orders."ShipAddress" AS Orders_ShipAddress,
     Orders."ShipCity" AS Orders_ShipCity,
     Orders."ShipRegion" AS Orders_ShipRegion,
     Orders."ShipPostalCode" AS Orders_ShipPostalCode,
     Orders."ShipCountry" AS Orders_ShipCountry,
     Products."ProductID" AS Products_ProductID,
     Products."ProductName" AS Products_ProductName,
     Products."SupplierID" AS Products_SupplierID,
     Products."CategoryID" AS Products_CategoryID,
     Products."QuantityPerUnit" AS Products_QuantityPerUnit,
     Products."UnitPrice" AS Products_UnitPrice,
     Products."UnitsInStock" AS Products_UnitsInStock,
     Products."UnitsOnOrder" AS Products_UnitsOnOrder,
     Products."ReorderLevel" AS Products_ReorderLevel,
     Products."Discontinued" AS Products_Discontinued,
     Region."RegionID" AS Region_RegionID,
     Region."RegionDescription" AS Region_RegionDescription,
     Shippers."ShipperID" AS Shippers_ShipperID,
     Shippers."CompanyName" AS Shippers_CompanyName,
     Shippers."Phone" AS Shippers_Phone,
     Suppliers."SupplierID" AS Suppliers_SupplierID,
     Suppliers."CompanyName" AS Suppliers_CompanyName,
     Suppliers."ContactName" AS Suppliers_ContactName,
     Suppliers."ContactTitle" AS Suppliers_ContactTitle,
     Suppliers."Address" AS Suppliers_Address,
     Suppliers."City" AS Suppliers_City,
     Suppliers."Region" AS Suppliers_Region,
     Suppliers."PostalCode" AS Suppliers_PostalCode,
     Suppliers."Country" AS Suppliers_Country,
     Suppliers."Phone" AS Suppliers_Phone,
     Suppliers."Fax" AS Suppliers_Fax,
     Suppliers."HomePage" AS Suppliers_HomePage,
     Territories."TerritoryID" AS Territories_TerritoryID,
     Territories."TerritoryDescription" AS Territories_TerritoryDescription,
     Territories."RegionID" AS Territories_RegionID,
     Users."UserId" AS Users_UserId,
     Users."EmployeeId" AS Users_EmployeeId,
     Users."userIdentification" AS Users_userIdentification,
     Users."password" AS Users_password,
     Users."status" AS Users_status
FROM
     "dbo"."CustomerDemographics" CustomerDemographics INNER JOIN "dbo"."CustomerCustomerDemo" CustomerCustomerDemo ON CustomerDemographics."CustomerTypeID" = CustomerCustomerDemo."CustomerTypeID"
     INNER JOIN "dbo"."Customers" Customers ON CustomerCustomerDemo."CustomerID" = Customers."CustomerID"
     INNER JOIN "dbo"."Orders" Orders ON Customers."CustomerID" = Orders."CustomerID"
     INNER JOIN "dbo"."Employees" Employees ON Orders."EmployeeID" = Employees."EmployeeID"
     INNER JOIN "dbo"."Order Details" Order_Details ON Orders."OrderID" = Order_Details."OrderID"
     INNER JOIN "dbo"."Shippers" Shippers ON Orders."ShipVia" = Shippers."ShipperID"
     INNER JOIN "dbo"."Products" Products ON Order_Details."ProductID" = Products."ProductID"
     INNER JOIN "dbo"."Categories" Categories ON Products."CategoryID" = Categories."CategoryID"
     INNER JOIN "dbo"."Suppliers" Suppliers ON Products."SupplierID" = Suppliers."SupplierID"
     INNER JOIN "dbo"."EmployeeTerritories" EmployeeTerritories ON Employees."EmployeeID" = EmployeeTerritories."EmployeeID"
     INNER JOIN "dbo"."Users" Users ON Employees."EmployeeID" = Users."EmployeeId"
     INNER JOIN "dbo"."Territories" Territories ON EmployeeTerritories."TerritoryID" = Territories."TerritoryID"
     INNER JOIN "dbo"."Region" Region ON Territories."RegionID" = Region."RegionID"
		</queryString>
