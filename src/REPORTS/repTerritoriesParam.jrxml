	<parameter name="paraRegID" class="java.lang.Integer">
		<defaultValueExpression />
	</parameter>
	<queryString>
		SELECT
    T."TerritoryID" AS Territories_TerritoryID,
    T."TerritoryDescription" AS Territories_TerritoryDescription,
    R."RegionDescription" AS Region_Description
FROM
    "dbo"."Territories" T
INNER JOIN
    "dbo"."Region" R
    ON T."RegionID" = R."RegionID"
WHERE
    T."RegionID" = 4;
	</queryString>
	<field name="Territories_TerritoryID" class="java.lang.String" />
	<field name="Territories_TerritoryDescription" class="java.lang.String" />
	<field name="Region_Description" class="java.lang.String" />
